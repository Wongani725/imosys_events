{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^7.3|^8.0",
        "ext-json": "*",
        "barryvdh/laravel-dompdf": "^2.2",
        "biscolab/laravel-recaptcha": "^5.4",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "guzzlehttp/psr7": "1.*",
        "intervention/image": "^2.7",
        "laravel/framework": "^8.75",
        "laravel/jetstream": "^2.8",
        "laravel/sanctum": "^2.15",
        "laravel/tinker": "^2.5",
        "livewire/livewire": "^2.5",
        "maatwebsite/excel": "^3.1",
        "mtownsend/request-xml": "^2.2",
        "phpoffice/phpspreadsheet": "^1.28",
        "propaganistas/laravel-disposable-email": "^2.1",
        "rap2hpoutre/fast-excel": "^5.4",
        "simplesoftwareio/simple-qrcode": "~4",
        "sparors/laravel-ussd": "^2.5",
        "spatie/laravel-activitylog": "^3.17",
        "spatie/laravel-permission": "^5.5",
        "symfony/http-client": "^5.4",
        "symfony/mailgun-mailer": "^5.4",
        "tecnickcom/tcpdf": "*"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.7",
        "barryvdh/laravel-ide-helper": "^2.12",
        "beyondcode/laravel-query-detector": "^1.6",
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^5.10",
        "phpunit/phpunit": "^9.5.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/constants.php",
            "app/Helpers/Helper.php",
            "app/Helpers/UserSession.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://satis.spatie.be"
        }
    ]
}
